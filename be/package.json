{
    "name": "atp-backend",
    "version": "2.0.0",
    "description": "ALLthePREACHING.com Backend API",
    "main": "server.js",
    "scripts": {
        "dev": "nodemon server.js",
        "start": "node server.js",
        "db:postgres:init": "node scripts/migrateMariaDbToPostgres.js --init-only",
        "db:postgres:import": "node scripts/migrateMariaDbToPostgres.js",
        "db:postgres:index-subtitles": "node scripts/indexSubtitlesToPostgres.js",
        "bible:build": "node scripts/buildBibleManifest.js",
        "scripture-video:render": "node scripts/renderScriptureVideo.js",
        "scripture-video:render-all": "node scripts/renderAllScriptureVideos.js",
        "scripture-video:prepare-youtube-all": "node scripts/prepareAllScriptureYouTubeBundle.js",
        "scripture-video:subtitles-all": "node scripts/renderAllYouTubeSubtitles.js",
        "scripture-video:youtube-manifest": "node scripts/buildYouTubeUploadManifest.js",
        "scripture-video:prepare-youtube": "node scripts/prepareScriptureYouTubeBundle.js",
        "scripture-video:render:av1": "node scripts/renderScriptureVideo.js --profile av1",
        "scripture-video:render:gpu": "node scripts/renderScriptureVideo.js --profile gpu",
        "test": "jest --coverage",
        "test:watch": "jest --watch"
    },
    "dependencies": {
        "compression": "^1.8.0",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^4.21.2",
        "express-rate-limit": "^7.5.0",
        "helmet": "^8.0.0",
        "mysql2": "^3.22.3",
        "pg": "^8.20.0",
        "rss": "^1.2.2"
    },
    "devDependencies": {
        "jest": "^30.3.0",
        "nodemon": "^3.1.9",
        "supertest": "^7.0.0"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
