  "verses": [
    {
      "verse": 1,
      "text": "A Song of degrees. They that trust in the LORD shall be as mount Zion, which cannot be removed, but abideth for ever.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_125_001.mp3"
    },
    {
      "verse": 2,
      "text": "As the mountains are round about Jerusalem, so the LORD is round about his people from henceforth even for ever.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_125_002.mp3"
    },
    {
      "verse": 3,
      "text": "For the rod of the wicked shall not rest upon the lot of the righteous; lest the righteous put forth their hands unto iniquity.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_125_003.mp3"
    },
    {
      "verse": 4,
      "text": "Do good, O LORD, unto those that be good, and to them that are upright in their hearts.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_125_004.mp3"
    },
    {
      "verse": 5,
      "text": "As for such as turn aside unto their crooked ways, the LORD shall lead them forth with the workers of iniquity: but peace shall be upon Israel.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_125_005.mp3"
    }
  ],
