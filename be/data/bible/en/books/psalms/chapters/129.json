  "verses": [
    {
      "verse": 1,
      "text": "A Song of degrees. Many a time have they afflicted me from my youth, may Israel now say:",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_129_001.mp3"
    },
    {
      "verse": 2,
      "text": "Many a time have they afflicted me from my youth: yet they have not prevailed against me.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_129_002.mp3"
    },
    {
      "verse": 3,
      "text": "The plowers plowed upon my back: they made long their furrows.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_129_003.mp3"
    },
    {
      "verse": 4,
      "text": "The LORD is righteous: he hath cut asunder the cords of the wicked.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_129_004.mp3"
    },
    {
      "verse": 5,
      "text": "Let them all be confounded and turned back that hate Zion.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_129_005.mp3"
    },
    {
      "verse": 6,
      "text": "Let them be as the grass upon the housetops, which withereth afore it groweth up:",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_129_006.mp3"
    },
    {
      "verse": 7,
      "text": "Wherewith the mower filleth not his hand; nor he that bindeth sheaves his bosom.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_129_007.mp3"
    },
    {
      "verse": 8,
      "text": "Neither do they which go by say, The blessing of the LORD be upon you: we bless you in the name of the LORD.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_129_008.mp3"
    }
  ],
