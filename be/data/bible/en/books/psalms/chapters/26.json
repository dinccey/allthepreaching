  },
  "verses": [
    {
      "verse": 1,
      "text": "A Psalm of David. Judge me, O LORD; for I have walked in mine integrity: I have trusted also in the LORD; therefore I shall not slide.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_001.mp3"
    },
    {
      "verse": 2,
      "text": "Examine me, O LORD, and prove me; try my reins and my heart.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_002.mp3"
    },
    {
      "verse": 3,
      "text": "For thy lovingkindness is before mine eyes: and I have walked in thy truth.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_003.mp3"
    },
    {
      "verse": 4,
      "text": "I have not sat with vain persons, neither will I go in with dissemblers.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_004.mp3"
    },
    {
      "verse": 5,
      "text": "I have hated the congregation of evil doers; and will not sit with the wicked.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_005.mp3"
    },
    {
      "verse": 6,
      "text": "I will wash mine hands in innocency: so will I compass thine altar, O LORD:",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_006.mp3"
    },
    {
      "verse": 7,
      "text": "That I may publish with the voice of thanksgiving, and tell of all thy wondrous works.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_007.mp3"
    },
    {
      "verse": 8,
      "text": "LORD, I have loved the habitation of thy house, and the place where thine honour dwelleth.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_008.mp3"
    },
    {
      "verse": 9,
      "text": "Gather not my soul with sinners, nor my life with bloody men:",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_009.mp3"
    },
    {
      "verse": 10,
      "text": "In whose hands is mischief, and their right hand is full of bribes.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_010.mp3"
    },
    {
      "verse": 11,
      "text": "But as for me, I will walk in mine integrity: redeem me, and be merciful unto me.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_011.mp3"
    },
    {
      "verse": 12,
      "text": "My foot standeth in an even place: in the congregations will I bless the LORD.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_026_012.mp3"
    }
  ],
