  "verses": [
    {
      "verse": 1,
      "text": "To the chief Musician, A Psalm of David, to bring to remembrance. Make haste , O God, to deliver me; make haste to help me, O LORD.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_070_001.mp3"
    },
    {
      "verse": 2,
      "text": "Let them be ashamed and confounded that seek after my soul: let them be turned backward, and put to confusion, that desire my hurt.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_070_002.mp3"
    },
    {
      "verse": 3,
      "text": "Let them be turned back for a reward of their shame that say, Aha, aha.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_070_003.mp3"
    },
    {
      "verse": 4,
      "text": "Let all those that seek thee rejoice and be glad in thee: and let such as love thy salvation say continually, Let God be magnified.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_070_004.mp3"
    },
    {
      "verse": 5,
      "text": "But I am poor and needy: make haste unto me, O God: thou art my help and my deliverer; O LORD, make no tarrying.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_070_005.mp3"
    }
  ],
