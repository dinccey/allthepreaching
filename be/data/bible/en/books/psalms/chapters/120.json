  "verses": [
    {
      "verse": 1,
      "text": "A Song of degrees. In my distress I cried unto the LORD, and he heard me.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_120_001.mp3"
    },
    {
      "verse": 2,
      "text": "Deliver my soul, O LORD, from lying lips, and from a deceitful tongue.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_120_002.mp3"
    },
    {
      "verse": 3,
      "text": "What shall be given unto thee? or what shall be done unto thee, thou false tongue?",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_120_003.mp3"
    },
    {
      "verse": 4,
      "text": "Sharp arrows of the mighty, with coals of juniper.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_120_004.mp3"
    },
    {
      "verse": 5,
      "text": "Woe is me, that I sojourn in Mesech, that I dwell in the tents of Kedar!",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_120_005.mp3"
    },
    {
      "verse": 6,
      "text": "My soul hath long dwelt with him that hateth peace.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_120_006.mp3"
    },
    {
      "verse": 7,
      "text": "I am for peace: but when I speak, they are for war.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_120_007.mp3"
    }
  ],
