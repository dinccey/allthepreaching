  "verses": [
    {
      "verse": 1,
      "text": "A Song of degrees of David. LORD, my heart is not haughty, nor mine eyes lofty: neither do I exercise myself in great matters, or in things too high for me.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_131_001.mp3"
    },
    {
      "verse": 2,
      "text": "Surely I have behaved and quieted myself, as a child that is weaned of his mother: my soul is even as a weaned child.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_131_002.mp3"
    },
    {
      "verse": 3,
      "text": "Let Israel hope in the LORD from henceforth and for ever.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_131_003.mp3"
    }
  ],
