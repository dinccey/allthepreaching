  "verses": [
    {
      "verse": 1,
      "text": "A Song of degrees of David. Behold, how good and how pleasant it is for brethren to dwell together in unity!",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_133_001.mp3"
    },
    {
      "verse": 2,
      "text": "It is like the precious ointment upon the head, that ran down upon the beard, even Aaron's beard: that went down to the skirts of his garments;",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_133_002.mp3"
    },
    {
      "verse": 3,
      "text": "As the dew of Hermon, and as the dew that descended upon the mountains of Zion: for there the LORD commanded the blessing, even life for evermore.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/19-psalms/19_PSA_133_003.mp3"
    }
  ],
