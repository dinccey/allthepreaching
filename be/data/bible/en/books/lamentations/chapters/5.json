{
  "language": "en",
  "translationLabel": "KJV",
  "book": {
    "id": "lamentations",
    "name": "Lamentations",
    "bookIndex": 25
  },
  "chapter": 5,
  "chapterCount": 5,
  "hasAudio": true,
  "audio": {
    "bookIntro": {
      "available": true,
      "path": "Waggoner_verses/25-lamentations/25_LAM_00_00.mp3"
    },
    "chapterIntro": {
      "available": true,
      "path": "Waggoner_verses/25-lamentations/25_LAM_05_00.mp3"
    }
  },
  "verses": [
    {
      "verse": 1,
      "text": "Remember, O LORD, what is come upon us: consider, and behold our reproach.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_01.mp3"
    },
    {
      "verse": 2,
      "text": "Our inheritance is turned to strangers, our houses to aliens.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_02.mp3"
    },
    {
      "verse": 3,
      "text": "We are orphans and fatherless, our mothers are as widows.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_03.mp3"
    },
    {
      "verse": 4,
      "text": "We have drunken our water for money; our wood is sold unto us.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_04.mp3"
    },
    {
      "verse": 5,
      "text": "Our necks are under persecution: we labour, and have no rest.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_05.mp3"
    },
    {
      "verse": 6,
      "text": "We have given the hand to the Egyptians, and to the Assyrians, to be satisfied with bread.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_06.mp3"
    },
    {
      "verse": 7,
      "text": "Our fathers have sinned, and are not; and we have borne their iniquities.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_07.mp3"
    },
    {
      "verse": 8,
      "text": "Servants have ruled over us: there is none that doth deliver us out of their hand.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_08.mp3"
    },
    {
      "verse": 9,
      "text": "We gat our bread with the peril of our lives because of the sword of the wilderness.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_09.mp3"
    },
    {
      "verse": 10,
      "text": "Our skin was black like an oven because of the terrible famine.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_10.mp3"
    },
    {
      "verse": 11,
      "text": "They ravished the women in Zion, and the maids in the cities of Judah.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_11.mp3"
    },
    {
      "verse": 12,
      "text": "Princes are hanged up by their hand: the faces of elders were not honoured.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_12.mp3"
    },
    {
      "verse": 13,
      "text": "They took the young men to grind, and the children fell under the wood.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_13.mp3"
    },
    {
      "verse": 14,
      "text": "The elders have ceased from the gate, the young men from their musick.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_14.mp3"
    },
    {
      "verse": 15,
      "text": "The joy of our heart is ceased; our dance is turned into mourning.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_15.mp3"
    },
    {
      "verse": 16,
      "text": "The crown is fallen from our head: woe unto us, that we have sinned!",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_16.mp3"
    },
    {
      "verse": 17,
      "text": "For this our heart is faint; for these things our eyes are dim.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_17.mp3"
    },
    {
      "verse": 18,
      "text": "Because of the mountain of Zion, which is desolate, the foxes walk upon it.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_18.mp3"
    },
    {
      "verse": 19,
      "text": "Thou, O LORD, remainest for ever; thy throne from generation to generation.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_19.mp3"
    },
    {
      "verse": 20,
      "text": "Wherefore dost thou forget us for ever, and forsake us so long time?",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_20.mp3"
    },
    {
      "verse": 21,
      "text": "Turn thou us unto thee, O LORD, and we shall be turned; renew our days as of old.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_21.mp3"
    },
    {
      "verse": 22,
      "text": "But thou hast utterly rejected us; thou art very wroth against us.",
      "hasAudio": true,
      "audioPath": "Waggoner_verses/25-lamentations/25_LAM_05_22.mp3"
    }
  ],
