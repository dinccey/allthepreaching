USE_MOCK_DB=false

# Remote MariaDB source used only for the one-time migration import
SOURCE_DB_HOST=192.168.100.149
SOURCE_DB_PORT=3306
SOURCE_DB_USER=alltdjli
SOURCE_DB_PASS=Um+2W=$-N_b+
SOURCE_DB_NAME=alltdjli_pas

# PostgreSQL service used by the compose stack
POSTGRES_DB=alltdjli_pas
POSTGRES_USER=alltdjli
POSTGRES_PASSWORD=Um+2W=$-N_b+
POSTGRES_PORT=5432
DB_CLIENT=postgres
DB_CONNECTION_LIMIT=20

# App configuration
BACKEND_PORT=3001
NODE_ENV=production

# CORS configuration
CORS_ORIGIN=https://allthepreaching.com,https://www.allthepreaching.com

# Video provider configuration
VIDEO_SOURCE=caddy
CADDY_BASE_URL=https://kjv1611only.com/video

# API security
API_CLONE_KEY=local_dev_key

# Backend-owned Postgres search; keep empty unless you still want the legacy external proxy path.
SEARCH_SERVICE_URL=

# Frontend configuration
NEXT_PUBLIC_API_URL=https://api.allthepreaching.com
NEXT_PUBLIC_SITE_URL=https://allthepreaching.com

# FTS worker configuration
INDEXER_ENABLED=true
INDEXER_SOURCE_SUBTITLE_ROOT=/home/shared/video
INDEXER_BATCH_SIZE=250
INDEXER_RUN_ON_STARTUP=false
INDEXER_STARTUP_MODE=incremental
INDEXER_EXIT_AFTER_STARTUP_RUN=false
INDEXER_SCAN_CRON=0 0 */3 * * *
INDEXER_TRACKED_FILE_CRON=0 30 */3 * * *
INDEXER_CLEANUP_CRON=0 0 12 * * *
