# Environment template for production
# Copy to .env and fill in actual values

# Database Configuration
POSTGRES_DB=allthepreaching
POSTGRES_USER=atp_postgres
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
DB_CLIENT=postgres
DB_CONNECTION_LIMIT=20

# One-time MariaDB source import
SOURCE_DB_HOST=
SOURCE_DB_PORT=3306
SOURCE_DB_USER=
SOURCE_DB_PASS=
SOURCE_DB_NAME=

# App Ports
BACKEND_PORT=3001

# Video Provider
VIDEO_SOURCE=caddy
CADDY_BASE_URL=https://videos.allthepreaching.com
BIBLE_AUDIO_BASE_URL=https://kjv1611only.com/video/kjv_audio
BIBLE_AUDIO_BASE_URL_EN=https://kjv1611only.com/video/kjv_audio
# Future languages can override separately, for example:
# BIBLE_AUDIO_BASE_URL_ES=https://example.com/video/kjv_audio_es
CADDY_VIDEO_PATH=/var/videos

# For MinIO/S3 (if using)
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=atp-videos

# API Configuration
# CORS_ORIGIN can be a comma-separated list of origins. Include frontend origin and legacy domains.
# Example: http://localhost:3000,https://www.kjv1611only.com,https://kjv1611only.com
CORS_ORIGIN=http://localhost:3000,https://www.kjv1611only.com,https://kjv1611only.com
API_CLONE_KEY=

# Legacy external search proxy (optional). Leave blank when backend-owned Postgres search is used.
SEARCH_SERVICE_URL=

# FTS Worker
INDEXER_ENABLED=true
INDEXER_SOURCE_SUBTITLE_ROOT=./subtitles_corpus/captions_backup2025
INDEXER_BATCH_SIZE=250
INDEXER_RUN_ON_STARTUP=false
INDEXER_STARTUP_MODE=incremental
INDEXER_EXIT_AFTER_STARTUP_RUN=false
INDEXER_SCAN_CRON=0 */10 * * * *
INDEXER_TRACKED_FILE_CRON=0 */20 * * * *
INDEXER_CLEANUP_CRON=0 */30 * * * *

# Frontend URLs
NEXT_PUBLIC_API_URL=https://api.allthepreaching.com
NEXT_PUBLIC_SITE_URL=https://allthepreaching.com
